---
export type TextureType = "solid" | "crosshatch" | "diagonal" | "chevron";
export type WidthType = "small" | "medium" | "large";

interface Props {
  texture?: TextureType;
  width?: WidthType;
  className?: string;
}

const { texture = "diagonal", width = "medium", className } = Astro.props;

const patterns: Record<TextureType, string> = {
  solid: "",
  crosshatch:
    "bg-[repeating-linear-gradient(45deg,transparent,transparent_2px,rgba(0,0,0,1)_2px,rgba(0,0,0,1)_4px),repeating-linear-gradient(-45deg,transparent,transparent_2px,rgba(0,0,0,1)_2px,rgba(0,0,0,1)_4px)]",
  diagonal:
    "bg-[repeating-linear-gradient(-45deg,rgba(0,0,0,1),rgba(0,0,0,1)_1px,transparent_1px,transparent_6px)]",
  chevron:
    "bg-[repeating-linear-gradient(45deg,rgba(0,0,0,1)_0px,rgba(0,0,0,1)_2px,transparent_2px,transparent_8px),repeating-linear-gradient(-45deg,rgba(0,0,0,1)_0px,rgba(0,0,0,1)_2px,transparent_2px,transparent_8px)]",
};

const widths: Record<WidthType, string> = {
  small: "h md:w",
  medium: "h-6 md:w-6",
  large: "h-12 md:w-12",
};

const pattern = patterns[texture];
const dividerWidth = widths[width];
---

<div
  class:list={[
    "border-t border-b md:h-full md:border-t-0 md:border-b-0 md:border-l md:border-r border-[rgba(0,0,0,1)] opacity-10",
    pattern,
    dividerWidth,
    className,
  ]}
>
</div>
